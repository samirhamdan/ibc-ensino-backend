# Configurações do servidor Flask
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-segura
FLASK_ENV=development
APP_URL=http://localhost:5000

# Banco de dados — opcional em dev (usa SQLite local por padrão).
# Em produção (Vercel + Neon), defina a connection string do Postgres:
# DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require
# DATABASE_URL=

# Seed de produção (usado por seed_production.py)
ADMIN_EMAIL=admin@ibc.com
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Configurações de email (Gmail)
# Para Gmail: ative "Senhas de app" em myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-16-digitos
EMAIL_FROM_NAME=IBC Ensino

# Multi-tenancy (Release 0.9 — TEN-02)
# Domínio-base para resolução de tenant por subdomínio (ex.: xreducacao.com.br
# faz ibc.xreducacao.com.br resolver o tenant "ibc"). Sem esta variável, a
# resolução por subdomínio fica desativada (comportamento atual de produção);
# em dev, o header X-Tenant-Slug funciona como override.
# TENANT_BASE_DOMAIN=xreducacao.com.br

# RLS (Fase 4 — docs/RUNBOOK-RLS.md)
# URL privilegiada usada SÓ pelas migrações (alembic) quando a app passa a
# conectar com role sem BYPASSRLS. Sem esta variável, alembic usa DATABASE_URL.
# ALEMBIC_DATABASE_URL=postgresql://usuario_privilegiado:senha@host:5432/db

# Redis (Etapa 4.3 — opcional; fallback gracioso para memória sem ela)
# Com REDIS_URL: cache de tenant compartilhado entre workers + storage do
# rate limiting (pré-requisito para >1 worker/réplica). No Railway: criar o
# serviço Redis e referenciar ${{Redis.REDIS_URL}}.
# REDIS_URL=redis://default:senha@host:6379

# Modo manutenção (Fase 6 — docs/PLAYBOOK-MIGRACAO-0.9.md §Produção)
# MAINTENANCE_MODE=true derruba TODA rota (menos /health) com 503 — usar só
# durante a janela de deploy/migração de produção, nunca deixar ligada por
# padrão. Lida a cada request (sem cache); um redeploy sem rebuild no
# Railway já aplica a mudança de variável.
# MAINTENANCE_MODE=false
#
# Token opcional para rodar o smoke test de produção (lógica equivalente a
# scripts/rehearsal.sh, apontado pra prod) ENQUANTO a manutenção ainda
# protege o público — header X-Maintenance-Bypass: <token>. Sem esta
# variável, ninguém passa pela manutenção, nem com o header certo.
# MAINTENANCE_BYPASS_TOKEN=gere-com-secrets-token-hex-32
